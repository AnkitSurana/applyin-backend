# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: razorpay.com → Settings → API Keys
# Test keys: rzp_test_...   Live keys: rzp_live_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Get from: razorpay.com → Settings → Webhooks → your webhook → secret
RAZORPAY_WEBHOOK_SECRET=...

# ── URLs ──────────────────────────────────────────────────────────────────────
# Your deployed Render service URL (no trailing slash)
APP_URL=https://applyin-backend.onrender.com
BACKEND_URL=https://applyin-backend.onrender.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# MUST include your published Chrome extension ID and LinkedIn.
# Format: chrome-extension://<extension-id>,https://www.linkedin.com
# Without this, the extension's API calls are CORS-blocked in production.
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID,https://www.linkedin.com

# ── Security ──────────────────────────────────────────────────────────────────
# Random secret that gates /health/diagnostics and /docs.
# Generate: openssl rand -hex 20
# Leave unset to disable those endpoints entirely (recommended in production
# unless you actively need them - set and use, then unset again).
DIAGNOSTICS_KEY=

# ── Compliance ────────────────────────────────────────────────────────────────
# Set to true in production (this is the default).
# Only set false for a local debugging session - never in a live deploy.
ENFORCE_CONSENT=true
